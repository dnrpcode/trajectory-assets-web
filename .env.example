# ── Firebase (client-side, safe to expose) ─────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── AI Robo Advisor — SERVER-ONLY (no VITE_ prefix, set in Vercel dashboard) ──
# These are read by api/advisor/chat.ts Edge Function only — never sent to browser.
AI_API_KEY=your_openrouter_api_key_here
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=google/gemma-3-27b-it:free
